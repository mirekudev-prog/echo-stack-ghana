<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Archive — EchoStack</title>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{--ink:#1a1e29;--blue:#0077b6;--gold:#C8962E;--cream:#f5f5f5;--white:#fff;--border:#e0e0e0;--sidebar-w:260px;}
body{font-family:Georgia,serif;background:var(--cream);color:var(--ink);}
.sidebar{position:fixed;left:0;top:0;height:100vh;width:var(--sidebar-w);background:var(--ink);color:white;display:flex;flex-direction:column;z-index:1000;transition:transform .3s;overflow-y:auto;}
.sidebar-header{padding:1.25rem 1.25rem 1rem;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:space-between;}
.sidebar-logo{display:flex;align-items:center;gap:.6rem;text-decoration:none;}
.sidebar-logo img{width:36px;height:36px;border-radius:7px;object-fit:contain;}
.sidebar-logo span{font-size:1.2rem;font-weight:bold;color:white;}
.sidebar-close{display:none;background:none;border:none;color:rgba(255,255,255,.5);font-size:1.6rem;cursor:pointer;padding:2px 6px;}
@media(max-width:768px){.sidebar-close{display:block;}}
.user-pill{margin:1rem 1.25rem 0;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:10px;}
.user-av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#C8962E,#E8B84B);display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:700;color:var(--ink);flex-shrink:0;}
.user-name{font-size:.82rem;font-weight:600;color:white;}
.user-plan{font-size:.68rem;color:rgba(255,255,255,.4);margin-top:1px;}
.sidebar-nav{flex:1;padding:.75rem;}
.nav-label{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.25);padding:.75rem .75rem .4rem;}
.sidebar-nav a{display:flex;align-items:center;gap:.75rem;padding:.7rem .9rem;color:rgba(255,255,255,.6);text-decoration:none;border-radius:8px;margin-bottom:2px;font-size:.88rem;transition:all .2s;}
.sidebar-nav a:hover,.sidebar-nav a.active{background:rgba(255,255,255,.08);color:white;}
.sidebar-nav a svg{width:18px;height:18px;flex-shrink:0;}
.sidebar-footer{padding:1rem 1.25rem 1.5rem;border-top:1px solid rgba(255,255,255,.08);}
.btn-logout{width:100%;background:rgba(220,38,38,.15);border:1px solid rgba(220,38,38,.3);color:#f87171;padding:.7rem;border-radius:8px;font-size:.85rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:all .2s;}
.btn-logout:hover{background:rgba(220,38,38,.3);color:#fff;}
.main-wrapper{margin-left:var(--sidebar-w);min-height:100vh;display:flex;flex-direction:column;}
.mobile-bar{display:none;position:sticky;top:0;z-index:900;background:var(--ink);padding:.75rem 1rem;align-items:center;justify-content:space-between;border-bottom:2px solid var(--gold);}
.mobile-bar-logo{display:flex;align-items:center;gap:8px;text-decoration:none;}
.mobile-bar-logo img{width:28px;height:28px;border-radius:6px;}
.mobile-bar-logo span{font-weight:bold;color:white;font-size:1rem;}
.burger{background:none;border:none;color:rgba(255,255,255,.7);cursor:pointer;}
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:999;}
.overlay.show{display:block;}
@media(max-width:768px){.sidebar{transform:translateX(-100%);}.sidebar.open{transform:translateX(0);}.main-wrapper{margin-left:0;}.mobile-bar{display:flex;}}
/* ── Archive header ── */
.arc-header{background:var(--ink);color:white;padding:2.5rem 1.5rem 2rem;text-align:center;}
.arc-header h1{font-size:2rem;font-weight:bold;margin-bottom:.5rem;}
.arc-header p{color:rgba(255,255,255,.55);font-size:.95rem;}
/* ── Filter bar ── */
.filter-bar{background:white;border-bottom:1.5px solid var(--border);padding:1rem 1.5rem;display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;position:sticky;top:0;z-index:100;}
.filter-bar input{flex:1;min-width:200px;padding:.7rem 1rem;border:1.5px solid var(--border);border-radius:9px;font-size:.88rem;outline:none;font-family:Georgia,serif;}
.filter-bar input:focus{border-color:var(--blue);}
.filter-bar select{padding:.7rem 1rem;border:1.5px solid var(--border);border-radius:9px;font-size:.85rem;outline:none;background:white;}
/* ── Premium wall ── */
.prem-wall{max-width:520px;margin:3rem auto;text-align:center;padding:2.5rem 2rem;background:white;border:2px solid rgba(201,147,58,.3);border-radius:16px;box-shadow:0 8px 32px rgba(201,147,58,.1);}
.prem-wall h2{font-size:1.4rem;font-weight:bold;margin-bottom:.75rem;}
.prem-wall p{color:#666;font-size:.9rem;line-height:1.7;margin-bottom:1.5rem;}
.btn-gold{display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,#c9933a,#e8b45a);color:var(--ink);padding:.9rem 2rem;border-radius:10px;font-size:.95rem;font-weight:700;text-decoration:none;border:none;cursor:pointer;transition:opacity .2s;}
.btn-gold:hover{opacity:.9;}
/* ── Archive content ── */
.arc-main{max-width:860px;margin:0 auto;padding:1.5rem 1rem 3rem;flex:1;}
/* Tab pills */
.type-pills{display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap;}
.pill{padding:6px 18px;border-radius:20px;font-size:.82rem;font-weight:700;cursor:pointer;border:1.5px solid var(--border);background:white;color:#666;transition:all .2s;}
.pill.active{background:var(--ink);color:white;border-color:var(--ink);}
/* Month group */
.month-group{margin-bottom:2rem;}
.month-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#999;padding-bottom:.6rem;border-bottom:1.5px solid var(--border);margin-bottom:.85rem;}
/* Post row */
.arc-row{display:flex;gap:1rem;align-items:flex-start;padding:.9rem 0;border-bottom:1px solid #f0f0f0;text-decoration:none;color:var(--ink);transition:all .2s;}
.arc-row:hover{background:rgba(0,119,182,.03);border-radius:8px;padding-left:.5rem;}
.arc-row:last-child{border-bottom:none;}
.arc-cover{width:72px;height:54px;border-radius:7px;object-fit:cover;flex-shrink:0;}
.arc-cover-ph{width:72px;height:54px;border-radius:7px;background:linear-gradient(135deg,#e8f0ff,#dbeafe);display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;}
.arc-info{flex:1;min-width:0;}
.arc-title{font-weight:700;font-size:.95rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:.25rem;}
.arc-excerpt{font-size:.82rem;color:#666;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:.3rem;}
.arc-meta{display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;}
.arc-badge{display:inline-block;padding:2px 9px;border-radius:12px;font-size:.65rem;font-weight:700;text-transform:uppercase;}
.badge-article{background:#dbeafe;color:#1d4ed8;}
.badge-story{background:#dcfce7;color:#15803d;}
.badge-video{background:#faf5ff;color:#7e22ce;}
.badge-prem{background:rgba(201,147,58,.12);color:#c9933a;}
.arc-date{font-size:.72rem;color:#aaa;white-space:nowrap;}
/* Locked row */
.arc-row-locked{opacity:.55;pointer-events:none;cursor:default;}
.lock-icon{color:#c9933a;font-size:.9rem;flex-shrink:0;}
/* Empty */
.empty{text-align:center;padding:3rem 1rem;color:#aaa;}
.empty-icon{font-size:3rem;margin-bottom:1rem;}
/* Stats bar */
.stats-strip{display:flex;gap:1.5rem;background:white;border:1.5px solid var(--border);border-radius:10px;padding:.9rem 1.25rem;margin-bottom:1.5rem;flex-wrap:wrap;}
.strip-item{text-align:center;flex:1;}
.strip-val{font-size:1.3rem;font-weight:800;color:var(--ink);}
.strip-lbl{font-size:.68rem;color:#888;text-transform:uppercase;letter-spacing:.06em;}
</style>
</head>
<body>
<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <a href="/app" class="sidebar-logo">
      <img src="/echostack-logo.png" onerror="this.style.display='none'">
      <span>EchoStack</span>
    </a>
