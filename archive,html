</aside>

<div class="main-wrapper">
  <div class="mobile-bar">
    <a href="/app" class="mobile-bar-logo"><img src="/echostack-logo.png" onerror="this.style.display='none'"><span>EchoStack</span></a>
    <button class="burger" onclick="openSidebar()"><svg width="24" height="24" fill="none" stroke="white" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg></button>
  </div>

  <div class="arc-header">
    <h1>🗂️ Archive</h1>
    <p id="arc-sub">Every published piece of Ghana's heritage — searchable, filterable, all in one place.</p>
  </div>

  <div class="filter-bar">
    <input type="text" id="arc-search" placeholder="🔍 Search articles, stories, videos…" oninput="filterAll()">
    <select id="arc-author-filter" onchange="filterAll()">
      <option value="">All creators</option>
    </select>
    <select id="arc-region-filter" onchange="filterAll()">
      <option value="">All regions</option>
    </select>
  </div>

  <!-- Premium wall (shown to free users) -->
  <div id="prem-wall" style="display:none;padding:1.5rem 1rem;">
    <div class="prem-wall">
      <div style="font-size:3rem;margin-bottom:1rem;">🔐</div>
      <h2>Full Archive is a Premium Feature</h2>
      <p>Premium members get access to the complete EchoStack archive — every article, story, and video ever published about Ghana's heritage, searchable by date, creator, and region.</p>
      <p style="margin-bottom:1.5rem;"><strong>Free members</strong> can read the 10 most recent posts. Upgrade to unlock everything.</p>
      <a href="/premium" class="btn-gold">⭐ Upgrade to Premium — GH₵150/mo</a>
      <p style="font-size:.78rem;color:#aaa;margin-top:1rem;">You can cancel anytime.</p>
    </div>
  </div>

  <div class="arc-main" id="arc-main">
    <!-- type pills -->
    <div class="type-pills">
      <div class="pill active" onclick="setTypePill('', this)">All</div>
      <div class="pill" onclick="setTypePill('article', this)">📰 Articles</div>
      <div class="pill" onclick="setTypePill('story', this)">📖 Stories</div>
      <div class="pill" onclick="setTypePill('video', this)">🎬 Videos</div>
      <div class="pill" onclick="setTypePill('premium', this)">⭐ Premium</div>
    </div>

    <!-- Stats strip -->
    <div class="stats-strip">
      <div class="strip-item"><div class="strip-val" id="s-total">–</div><div class="strip-lbl">Total Posts</div></div>
      <div class="strip-item"><div class="strip-val" id="s-articles">–</div><div class="strip-lbl">Articles</div></div>
      <div class="strip-item"><div class="strip-val" id="s-stories">–</div><div class="strip-lbl">Stories</div></div>
      <div class="strip-item"><div class="strip-val" id="s-videos">–</div><div class="strip-lbl">Videos</div></div>
      <div class="strip-item"><div class="strip-val" id="s-prem">–</div><div class="strip-lbl">Premium</div></div>
    </div>

    <div id="arc-content"><div class="empty"><div class="empty-icon">⏳</div><p>Loading archive…</p></div></div>
  </div>

  <footer style="background:white;border-top:1px solid var(--border);padding:1rem;text-align:center;font-size:.8rem;color:#888;">
    © 2026 EchoStack — Preserving Ghana's Stories
  </footer>
</div>

<script>
var currentUser = {};
try { currentUser = JSON.parse(localStorage.getItem('es_user')) || {}; } catch(e) {}

var isCreator = ['creator','admin','superuser'].includes(currentUser.role);
var isPremium = currentUser.is_premium == 1 || currentUser.plan === 'premium' || isCreator;
var FREE_LIMIT = 10; // free users see last 10

// Sidebar init
if (currentUser.username) {
  document.getElementById('user-name').textContent = currentUser.username;
  document.getElementById('user-av').textContent = currentUser.username.charAt(0).toUpperCase();
  document.getElementById('user-plan').textContent = isCreator ? '✨ Creator' : (isPremium ? '⭐ Premium' : 'Free Plan');
  if (isCreator) { var nc = document.getElementById('nav-creator'); if(nc) nc.style.display='flex'; }
  if (!isPremium) { var cta = document.getElementById('upgrade-cta'); if(cta) cta.style.display='block'; }
}

function openSidebar(){document.getElementById('sidebar').classList.add('open');document.getElementById('overlay').classList.add('show');document.body.style.overflow='hidden';}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('overlay').classList.remove('show');document.body.style.overflow='';}
function logout(){fetch('/api/users/logout',{method:'POST'}).catch(()=>{});localStorage.removeItem('es_user');document.cookie='user_session=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC';window.location.href='/';}

// Show/hide premium wall
if (!isPremium) {
  document.getElementById('prem-wall').style.display = 'block';
  document.getElementById('arc-sub').textContent = 'Showing 10 most recent posts. Upgrade for full access.';
}

// State
var allPosts = [], activeType = '', activeSearch = '', activeAuthor = '', activeRegion = '';

async function loadArchive() {
  var limit = isPremium ? 500 : FREE_LIMIT;
  try {
    var res = await fetch('/api/posts?status=published&limit=' + limit);
    var data = await res.json();
    allPosts = Array.isArray(data) ? data : [];

    // Populate stats
    document.getElementById('s-total').textContent = allPosts.length + (isPremium ? '' : '+');
    document.getElementById('s-articles').textContent = allPosts.filter(p=>p.content_type==='article').length;
    document.getElementById('s-stories').textContent = allPosts.filter(p=>p.content_type==='story').length;
    document.getElementById('s-videos').textContent = allPosts.filter(p=>p.content_type==='video').length;
    document.getElementById('s-prem').textContent = allPosts.filter(p=>p.is_premium==1).length;

    // Populate author dropdown
    var authors = [...new Set(allPosts.map(p=>p.author_username).filter(Boolean))];
    var aSel = document.getElementById('arc-author-filter');
    authors.forEach(a => { var o=document.createElement('option'); o.value=a; o.textContent=a; aSel.appendChild(o); });

    // Populate region dropdown
    try {
      var rRes = await fetch('/api/regions');
      var regions = await rRes.json();
      var rSel = document.getElementById('arc-region-filter');
      regions.forEach(r => { var o=document.createElement('option'); o.value=r.id; o.textContent=r.name; rSel.appendChild(o); });
    } catch(e) {}

    renderArchive(allPosts);
  } catch(e) {
    document.getElementById('arc-content').innerHTML = '<div class="empty"><div class="empty-icon">⚠️</div><p>Failed to load archive. Please refresh.</p></div>';
  }
}

function setTypePill(type, el) {
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  activeType = type;
  filterAll();
}

function filterAll() {
  activeSearch = document.getElementById('arc-search').value.toLowerCase();
  activeAuthor = document.getElementById('arc-author-filter').value;
  activeRegion = document.getElementById('arc-region-filter').value;

  var filtered = allPosts.filter(p => {
    if (activeSearch && !(p.title||'').toLowerCase().includes(activeSearch) && !(p.excerpt||'').toLowerCase().includes(activeSearch) && !(p.author_username||'').toLowerCase().includes(activeSearch)) return false;
    if (activeAuthor && p.author_username !== activeAuthor) return false;
    if (activeRegion && String(p.region_id) !== String(activeRegion)) return false;
    if (activeType === 'premium') return p.is_premium == 1;
    if (activeType && p.content_type !== activeType) return false;
    return true;
  });

  renderArchive(filtered);
}

function renderArchive(posts) {
  var box = document.getElementById('arc-content');
  if (!posts.length) {
    box.innerHTML = '<div class="empty"><div class="empty-icon">📭</div><p>No posts match your filters.</p></div>';
    return;
  }

  // Group by month
  var groups = {};
  posts.forEach(p => {
    var d = new Date(p.created_at);
    var key = d.toLocaleString('default',{month:'long',year:'numeric'});
    if (!groups[key]) groups[key] = [];
    groups[key].push(p);
  });

  box.innerHTML = Object.entries(groups).map(([month, ps]) => `
    <div class="month-group">
      <div class="month-label">${month} <span style="font-weight:400;color:#bbb;">(${ps.length} post${ps.length!==1?'s':''})</span></div>
      ${ps.map(p => {
        var isLocked = p.is_premium == 1 && !isPremium;
        var icon = p.content_type==='video'?'🎬':p.content_type==='story'?'📖':'📰';
        var typeBadge = 'badge-' + (p.content_type||'article');
        var row = `<a href="${isLocked ? '/premium' : '/post/'+p.id}" class="arc-row${isLocked?' arc-row-locked':''}" style="${isLocked?'pointer-events:auto;cursor:pointer;':''}" title="${isLocked?'Premium — upgrade to read':''}">`;
        row += p.cover_image
          ? `<img class="arc-cover" src="${p.cover_image}" onerror="this.style.display='none'">`
          : `<div class="arc-cover-ph">${icon}</div>`;
        row += `<div class="arc-info">
          <div class="arc-title">${isLocked?'🔒 ':''}${p.title}</div>
          <div class="arc-excerpt">${p.excerpt||'No preview available.'}</div>
          <div class="arc-meta">
            <span class="arc-badge ${typeBadge}">${p.content_type||'article'}</span>
            ${p.is_premium ? '<span class="arc-badge badge-prem">⭐ Premium</span>' : ''}
            <span style="font-size:.72rem;color:#999;">${p.author_username||'EchoStack'}</span>
            <span style="font-size:.72rem;color:#bbb;">·</span>
            <span class="arc-date">${new Date(p.created_at).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}</span>
          </div>
        </div>`;
        if (isLocked) row += `<div class="lock-icon">🔒</div>`;
        row += '</a>';
        return row;
      }).join('')}
    </div>`).join('');

  // If free user, append upgrade prompt after content
  if (!isPremium) {
    box.innerHTML += `
      <div style="text-align:center;padding:2rem;background:white;border:2px dashed rgba(201,147,58,.3);border-radius:12px;margin-top:1rem;">
        <div style="font-size:1.5rem;margin-bottom:.5rem;">📚</div>
        <p style="font-weight:700;margin-bottom:.4rem;">You're seeing the ${FREE_LIMIT} most recent posts</p>
        <p style="color:#888;font-size:.88rem;margin-bottom:1rem;">Upgrade to Premium to access the complete EchoStack archive.</p>
        <a href="/premium" style="display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,#c9933a,#e8b45a);color:var(--ink);padding:.75rem 1.75rem;border-radius:9px;font-size:.9rem;font-weight:700;text-decoration:none;">⭐ Upgrade to Premium — GH₵150/mo</a>
      </div>`;
  }
}

loadArchive();
</script>
</body>
</html>
