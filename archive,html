  </nav>
  <div class="sidebar-footer">
    <a href="/premium" id="upgrade-cta" style="display:none;text-decoration:none;margin-bottom:10px;">
      <div style="background:linear-gradient(135deg,rgba(201,147,58,.18),rgba(201,147,58,.08));border:1px solid rgba(201,147,58,.3);border-radius:10px;padding:12px 14px;text-align:center;">
        <div style="font-size:.7rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#c9933a;margin-bottom:4px;">⭐ Upgrade to Premium</div>
        <div style="font-size:.72rem;color:#c9933a;font-weight:600;margin-top:4px;">GH₵150/month →</div>
      </div>
