  </div>
  <div class="user-pill">
    <div class="user-av" id="user-av">?</div>
    <div>
      <div class="user-name" id="user-name">Loading…</div>
      <div class="user-plan" id="user-plan">Free Plan</div>
    </div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-label">Explore</div>
    <a href="/app"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>Map & Regions</a>
    <a href="/dashboard"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v12a2 2 0 01-2 2z"/></svg>News Feed</a>
